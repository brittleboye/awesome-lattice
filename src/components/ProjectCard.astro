---
import { projectSlug, type Project } from '../data/projects';
import { tagHref } from '../lib/tags';

interface Props {
  project: Project;
  categoryId: string;
}

const { project, categoryId } = Astro.props;
const primary = project.homepage ?? project.repo ?? project.docs;
const base = import.meta.env.BASE_URL;
const normBase = base.endsWith('/') ? base.slice(0, -1) : base;
const detailHref = `${normBase}/projects/${categoryId}/${projectSlug(project)}/`;
---

<article class="card">
  <div class="card-head">
    <h2>
      <a href={primary} rel="noopener">{project.name}</a>
    </h2>
    {project.badge && <span class="badge">{project.badge}</span>}
  </div>
  <p>{project.description}</p>
  {project.tags && project.tags.length > 0 && (
    <div class="tag-row">
      {project.tags.map((t) => <a class="tag" href={tagHref(normBase, t)}>{t}</a>)}
    </div>
  )}
  <div class="card-links">
    {project.repo && <a href={project.repo} rel="noopener">Source</a>}
    {project.docs && <a href={project.docs} rel="noopener">Docs</a>}
    {project.homepage && project.homepage !== project.repo && (
      <a href={project.homepage} rel="noopener">Site</a>
    )}
    <a href={detailHref} class="card-more">More →</a>
  </div>
</article>
