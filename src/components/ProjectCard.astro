---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const primary = project.homepage ?? project.repo ?? project.docs;
---

<article class="card">
  <div class="card-head">
    <h3>
      <a href={primary} rel="noopener">{project.name}</a>
    </h3>
    {project.badge && <span class="badge">{project.badge}</span>}
  </div>
  <p>{project.description}</p>
  {project.tags && project.tags.length > 0 && (
    <div class="tag-row">
      {project.tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  )}
  <div class="card-links">
    {project.repo && <a href={project.repo} rel="noopener">Source</a>}
    {project.docs && <a href={project.docs} rel="noopener">Docs</a>}
    {project.homepage && project.homepage !== project.repo && (
      <a href={project.homepage} rel="noopener">Site</a>
    )}
  </div>
</article>
