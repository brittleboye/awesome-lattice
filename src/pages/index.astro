---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { categories } from '../data/projects';
import { categoryItemList } from '../lib/structured-data';

const active = categories[0];
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const itemList = categoryItemList(active, pageUrl);
---

<BaseLayout
  title="Awesome Lattice — a directory of lattice-powered tools & projects"
  description={`${active.description} Browse platforms, SDKs, MCP servers, apps, and organisations across the lattice ecosystem.`}
  structuredData={itemList}
>
  <div class="layout">
    <Sidebar activeId={active.id} />
    <div>
      <header class="page-head">
        <h1>{active.title}</h1>
        <p>{active.description}</p>
      </header>
      <div class="card-grid">
        {active.projects.map((project) => <ProjectCard project={project} categoryId={active.id} />)}
      </div>
    </div>
  </div>
</BaseLayout>
